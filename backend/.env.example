# ══════════════════════════════════════════════════
#  சித்த வளம் — Environment Variables v2
#  Copy this file as .env and fill in your values
# ══════════════════════════════════════════════════

# ── SERVER ────────────────────────────────────────
PORT=3000

# ── DATABASE (MongoDB Atlas) ──────────────────────
# Get from: mongodb.com/atlas → Connect → Drivers
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/siddha-valam

# ── PAYMENT (Razorpay) ───────────────────────────
# Get from: razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ── EMAIL (Gmail) ─────────────────────────────────
# Use Gmail App Password (not your real password)
# Setup: Google Account → Security → 2FA → App Passwords
EMAIL_USER=yourshop@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ── WHATSAPP & SMS (Twilio) ───────────────────────
# Get from: twilio.com → Console
# WhatsApp sandbox: twilio.com/try-twilio
TWILIO_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=+14155238886
TWILIO_SMS_FROM=+1xxxxxxxxxx

# ── SHOP INFO ─────────────────────────────────────
SHOP_WHATSAPP=+91 99628 05303
