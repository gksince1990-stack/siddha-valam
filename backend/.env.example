# ══════════════════════════════════════════════════
#  சித்த வளம் — Environment Variables
#  Copy this file as .env and fill in your values
# ══════════════════════════════════════════════════

# Server Port
PORT=3000

# MongoDB Atlas Connection String
# Get this from: mongodb.com/atlas → Connect → Drivers
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/siddha-valam

# Razorpay Keys
# Get from: razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Admin Password (change this!)
ADMIN_PASSWORD=siddha2024
